# OmniOps 环境配置
# 复制此文件为 .env 并填入真实值

# ===================
# 数据库配置
# ===================
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/omniops

# ===================
# Redis 配置
# ===================
REDIS_URL=redis://localhost:6379/0

# ===================
# LLM API 配置
# ===================
# 默认 provider: anthropic | openai | openrouter | minimax
LLM_PROVIDER=anthropic
LLM_MODEL=claude-3-5-sonnet-20241022

ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
ANTHROPIC_MAX_TOKENS=2048

# OpenAI（兼容 OpenAI API 接口的模型）
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# OpenRouter（https://openrouter.ai）
OPENROUTER_API_KEY=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
OPENROUTER_MODEL=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning:free

# MiniMax（https://www.minimax.cn）
MINIMAX_API_KEY=your_minimax_api_key_here
MINIMAX_MODEL=MiniMax-Text-01
MINIMAX_GROUP_ID=your_minimax_group_id_here

# ===================
# 向量数据库配置
# ===================
CHROMA_PERSISTENT_PATH=./data/chroma
CHROMA_COLLECTION=omniops_knowledge

# ===================
# Neo4j 配置
# ===================
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# ===================
# 应用配置
# ===================
OMNIOPS_API_HOST=0.0.0.0
OMNIOPS_API_PORT=8000
OMNIOPS_API_DEBUG=true

# 文件上传
OMNIOPS_UPLOAD_DIR=./uploads
OMNIOPS_MAX_UPLOAD_SIZE=10485760

# 日志级别
LOG_LEVEL=INFO

# ===================
# RabbitMQ 配置
# ===================
RABBITMQ_URL=amqp://omniops:omniops123@localhost:5672/
RABBITMQ_MANAGEMENT_URL=http://localhost:15672

# ===================
# HITL (人工审核) 配置
# ===================
# 人工审核超时时间（秒）
HITL_TIMEOUT_SECONDS=600
# 升级 webhook URL（可选，如企业微信机器人）
HITL_ESCALATION_WEBHOOK_URL=